# OMDb API key (get one at https://www.omdbapi.com/apikey.aspx)
OMDB_API_KEY=

# Discord webhook URL for notifications
RENAMARR_DISCORD_WEBHOOK=

# Discord bot for reaction-based approve/reject/ignore
RENAMARR_DISCORD_BOT_TOKEN=
RENAMARR_DISCORD_CHANNEL_ID=

# Web UI URL (used in Discord notification links)
RENAMARR_WEB_URL=

# API key to protect web endpoints (optional)
RENAMARR_API_KEY=

# Passphrase for destructive operations like trash deletion (optional)
RENAMARR_DELETE_PASSPHRASE=
